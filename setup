#!/usr/bin/env bash
# rstack setup — build browser binary + register all skills
set -e

RSTACK_DIR="$(cd "$(dirname "$0")" && pwd)"
SKILLS_DIR="$(dirname "$RSTACK_DIR")"
BROWSE_BIN="$RSTACK_DIR/browse/dist/browse"

# 1. Build browse binary if needed
NEEDS_BUILD=0
if [ ! -x "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
elif [ -n "$(find "$RSTACK_DIR/browse/src" -type f -newer "$BROWSE_BIN" -print -quit 2>/dev/null)" ]; then
  NEEDS_BUILD=1
elif [ "$RSTACK_DIR/package.json" -nt "$BROWSE_BIN" ]; then
  NEEDS_BUILD=1
fi

if [ "$NEEDS_BUILD" -eq 1 ]; then
  echo "Building browse binary..."
  if ! command -v bun &>/dev/null; then
    echo "Error: bun is required to build the browse binary."
    echo "Install it: curl -fsSL https://bun.sh/install | bash"
    exit 1
  fi
  (
    cd "$RSTACK_DIR"
    bun install --no-save
    bun run build
  )
fi

if [ ! -x "$BROWSE_BIN" ]; then
  echo "rstack setup failed: browse binary missing at $BROWSE_BIN" >&2
  exit 1
fi

# 2. Create skill symlinks if inside a skills directory
# Supports: .github/skills/, ~/.copilot/skills/
SKILLS_BASENAME="$(basename "$SKILLS_DIR")"
if [ "$SKILLS_BASENAME" = "skills" ]; then
  linked=()
  for skill_dir in "$RSTACK_DIR"/*/; do
    if [ -f "$skill_dir/SKILL.md" ]; then
      skill_name="$(basename "$skill_dir")"
      # Skip non-skill directories
      [ "$skill_name" = "node_modules" ] && continue
      [ "$skill_name" = "browse" ] && { [ ! -d "$skill_dir/src" ] || true; }
      target="$SKILLS_DIR/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "rstack/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done

  echo "rstack ready."
  echo "  browse binary: $BROWSE_BIN"
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
else
  echo "rstack ready."
  echo "  browse binary: $BROWSE_BIN"
  echo "  (skipped skill symlinks — not inside a skills/ directory)"
  echo ""
  echo "To register skills, move rstack into one of:"
  echo "  ~/.copilot/skills/rstack/     (personal, works with Copilot CLI)"
  echo "  .github/skills/rstack/        (project, works everywhere)"
fi
